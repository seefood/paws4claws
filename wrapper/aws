#!/bin/sh
# Drop-in aws wrapper for PAWS — forwards calls to the credential daemon.
# Install at /usr/local/bin/aws in agent containers.
# Requires: PAWS_TOKEN env var, curl, jq

PAWS_URL="${PAWS_URL:-http://paws:7142}"

# shellcheck source=wrapper/file_allowlist.sh
_allowlist="$(dirname "$0")/file_allowlist.sh"
if [ ! -f "$_allowlist" ]; then
	_allowlist="/usr/local/lib/paws/file_allowlist.sh"
fi
if [ ! -f "$_allowlist" ]; then
	echo "paws: file_allowlist.sh not found (install wrapper/ to /usr/local/lib/paws/)" >&2
	exit 1
fi
# shellcheck source=/dev/null
. "$_allowlist"

ARGS=$(printf '%s\n' "$@" | jq -R . | jq -sc .)
FILES=$(collect_inline_files "$@")

if [ ! -t 0 ]; then
	STDIN_B64=$(cat | base64 | tr -d '\n')
	if [ "$FILES" = "[]" ]; then
		PAYLOAD=$(jq -n --argjson args "$ARGS" --arg stdin "$STDIN_B64" \
			'{args: $args, stdin: $stdin}')
	else
		PAYLOAD=$(jq -n --argjson args "$ARGS" --argjson files "$FILES" --arg stdin "$STDIN_B64" \
			'{args: $args, files: $files, stdin: $stdin}')
	fi
elif [ "$FILES" = "[]" ]; then
	PAYLOAD=$(jq -n --argjson args "$ARGS" '{args: $args}')
else
	PAYLOAD=$(jq -n --argjson args "$ARGS" --argjson files "$FILES" \
		'{args: $args, files: $files}')
fi

if ! RESPONSE=$(curl -s \
	-H "Authorization: Bearer $PAWS_TOKEN" \
	-H "Content-Type: application/json" \
	-d "$PAYLOAD" \
	"$PAWS_URL/invoke") || [ -z "$RESPONSE" ]; then
	echo "paws: daemon unreachable" >&2
	exit 1
fi

# Error responses (4xx/5xx) carry an "error" field but no exitCode/stdout/stderr
if printf '%s' "$RESPONSE" | jq -e '.error' >/dev/null 2>&1; then
	printf '%s' "$RESPONSE" | jq -r '.message // .error' >&2
	exit 1
fi

EXIT_CODE=$(printf '%s' "$RESPONSE" | jq -r '.exitCode')
if [ "$EXIT_CODE" = "0" ]; then
	if ! write_output_files "$RESPONSE" "$@"; then
		exit 1
	fi
fi

printf '%s' "$RESPONSE" | jq -j '.stdout'
printf '%s' "$RESPONSE" | jq -j '.stderr' >&2
exit "$EXIT_CODE"
