# AWS credentials for the daemon
# Use a dedicated IAM user/role scoped to exactly what your agent needs.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
# AWS_PROFILE=           # alternative: use a named profile from ~/.aws/credentials

# Bearer tokens — one per client. Each agent container gets its own token.
# Generate with: openssl rand -hex 32
# Format TBD (env vars shown here as a candidate):
# PAWS_TOKEN_AGENT_A=
# PAWS_TOKEN_AGENT_B=
# All tokens map to the same IAM credentials in v1.

# Daemon listen port (default 7142)
# PAWS_PORT=7142

# Comma-separated list of allowed AWS services (overrides default allowlist)
# PAWS_ALLOWED_SERVICES=s3,ec2,logs,ssm,sts
